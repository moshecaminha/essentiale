# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://kxjposjzblsjnnxvxnqp.supabase.co

# Chave pública (publishable) — segura para o cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Chave de serviço (service_role) — SECRETA, só no servidor.
# Copie em: Supabase > Project Settings > API > service_role.
# Necessária para o painel ler clientes, pedidos e a base RFM (dados protegidos por RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Senha de acesso ao painel /admin. Defina na Vercel para ATIVAR a proteção.
# Enquanto estiver vazia, o /admin fica aberto (proteção desligada).
ADMIN_PASSWORD=

# E-mails transacionais (confirmação de pedido ao cliente). Opcional.
# Crie a chave em resend.com e verifique seu domínio de envio.
RESEND_API_KEY=
EMAIL_FROM=Essentiale <pedidos@essentialefragrance.com.br>
